        {
          "name": "Create User (Get API Key)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_dev\",\n  \"email\": \"john@example.com\",\n  \"full_name\": \"John Developer\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/api/users",
